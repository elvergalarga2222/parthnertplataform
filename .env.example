# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/partner_manager

# Redis (sesiones + BullMQ)
REDIS_URL=redis://localhost:6379

# Skool API (Fase 1)
SKOOL_API_KEY=
SKOOL_GROUP_ID=
SKOOL_WEBHOOK_SECRET=

# Solo desarrollo: emails permitidos para probar el login sin la API real de
# Skool (separados por coma). Ignorado en producción. No usar en prod.
AUTH_DEV_EMAILS=

# --- IA (módulo del workspace) ---
# Cifrado de las API keys BYOK del partner — 32 bytes en base64.
# Generar con: openssl rand -base64 32
AI_KEYS_MASTER_KEY=
# Proveedor de IA: "mock" (por defecto, dev/CI, sin red ni key) o "anthropic"
# (producción — cada partner pone su propia key BYOK; la plataforma nunca paga).
AI_PROVIDER=mock
# Modelo a usar cuando AI_PROVIDER=anthropic (default: claude-opus-4-8).
AI_MODEL=claude-opus-4-8

# --- Dominio / reverse proxy ---
# Dominios permitidos para Server Actions detrás de Nginx+HTTPS (separados por
# coma, SIN protocolo). Imprescindible al servir por un dominio distinto al
# host interno; si no coincide, Next rechaza todas las mutaciones. Ejemplo:
#   ALLOWED_ORIGINS=deno.arenacatticos.store,arenacatticos.store
ALLOWED_ORIGINS=

# --- Observabilidad ---
# Nivel mínimo de log: debug | info | warn | error (default: info en prod).
LOG_LEVEL=
# Etiqueta de versión que reporta /api/health (opcional; ej. el SHA del deploy).
APP_VERSION=
